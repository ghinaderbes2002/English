# ───── Database ─────
DB_USER=postgres
DB_PASSWORD=ChangeThisStrongPassword123!
DB_NAME=english

# ───── App ─────
APP_PORT=3015
TZ=Asia/Damascus
JWT_SECRET=change-this-to-a-very-long-random-secret-string
JWT_EXPIRES_IN=30d
MAX_FILE_SIZE=52428800
ADMIN_DEFAULT_PASSWORD=Admin@12345

# ───── First-time setup ─────
# خليها true بأول تشغيل عشان يعبي قاعدة البيانات بالبيانات الأولية
# بعد أول تشغيل ناجح، رجّعها false
RUN_SEED=false

# ───── AI Chat (Gemini) ─────
# احصل على المفتاح من: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# عدد الأسئلة المسموحة لكل طالب يومياً (عبر كل المحاضرات مجتمعة)
CHAT_LIMIT_PER_DAY=8